        </mxCell>
        <mxCell id="sc_store" value="Local SQLite&#10;+ encrypted key file" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
