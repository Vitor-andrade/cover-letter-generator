# Copy this file to `.env` and fill in the values you need.
# Every setting can also be passed as an environment variable (CLG_ prefix).

# Active AI provider: ollama (local, free) | gemini | anthropic | openai
CLG_AI_PROVIDER=ollama
CLG_DEFAULT_LANGUAGE=en

# Bring-your-own cloud provider keys — required only for the cloud provider you
# select above. Ollama runs locally and needs no key.
# CLG_GEMINI_API_KEY=your-gemini-key
# CLG_ANTHROPIC_API_KEY=your-anthropic-key
# CLG_OPENAI_API_KEY=your-openai-key
